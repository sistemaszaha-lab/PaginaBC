web: sh -c "python manage.py migrate && python manage.py collectstatic --noinput && python manage.py shell -c \"import os; from django.contrib.auth import get_user_model; U=get_user_model(); u=os.getenv('DJANGO_SUPERUSER_USERNAME'); e=os.getenv('DJANGO_SUPERUSER_EMAIL'); p=os.getenv('DJANGO_SUPERUSER_PASSWORD'); user=None; (u and e and p) and (user:=U.objects.filter(username=u).first() or U.objects.create_superuser(username=u, email=e, password=p)); user and (setattr(user,'email',e), setattr(user,'is_staff',True), setattr(user,'is_superuser',True), user.set_password(p), user.save())\" && gunicorn solicitudes_app.wsgi --bind 0.0.0.0:${PORT:-8000} --log-file -"
